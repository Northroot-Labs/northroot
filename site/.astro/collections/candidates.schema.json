{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "draft": {
      "default": true,
      "type": "boolean"
    },
    "generatedBy": {
      "type": "string"
    },
    "sourceRefs": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "repo": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "commit": {
            "type": "string"
          }
        },
        "required": [
          "repo"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "summary",
    "date",
    "generatedBy"
  ]
}