{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "section": {
      "type": "string",
      "enum": [
        "product",
        "systems",
        "examples",
        "architecture",
        "docs",
        "journal"
      ]
    },
    "sourceRefs": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "repo": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "commit": {
            "type": "string"
          }
        },
        "required": [
          "repo"
        ]
      }
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "section"
  ]
}