---
import Header from "../components/Header.astro";
import "../styles/global.css";

interface Props {
  description?: string;
  title?: string;
}

const { description = "Operational notes and public references for Northroot.", title = "northroot" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
  </body>
</html>
