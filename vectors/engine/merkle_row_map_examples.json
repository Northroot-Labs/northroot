{
  "description": "Merkle Row-Map examples demonstrating CBOR canonicalization (RFC 8949) for Merkle tree computation",
  "empty_map": {
    "description": "Empty Merkle Row-Map root",
    "entries": {},
    "root": "sha256:08679e383d66dbc4192bae473a37843066188e42635077349d1c7db7cf25b20c",
    "note": "Empty tree root = H(\"leaf:\" || \"\")"
  },
  "single_entry": {
    "description": "Single entry Merkle Row-Map",
    "entries": {
      "key1": 42
    },
    "root": "sha256:efc2744e9b28f4e70e3fa27213eff9a64c98bae3fd14c159cde674dcb607d66d",
    "note": "Leaf hash = H(\"leaf:\" || cbor_canonical({k, v}))"
  },
  "multiple_entries": {
    "description": "Multiple entries Merkle Row-Map",
    "entries": {
      "key1": 42,
      "key2": "value",
      "key3": true
    },
    "root": "sha256:a48477478dea2ee2360da4a3cd1ccfe278a49aa3be067d1286b6038e208fb600",
    "note": "Parent hash = H(\"node:\" || left || right), odd nodes promoted upward"
  },
  "order_independence": {
    "description": "Demonstrates order independence (BTreeMap maintains sorted order)",
    "map1": {
      "entries": {
        "a": 1,
        "b": 2
      },
      "root": "sha256:6ec2710445dd04ef7c157b5cbb2896590bcfb9dfa612f4754214de1c7da4ec99"
    },
    "map2": {
      "entries": {
        "b": 2,
        "a": 1
      },
      "root": "sha256:6ec2710445dd04ef7c157b5cbb2896590bcfb9dfa612f4754214de1c7da4ec99"
    },
    "roots_match": true,
    "note": "BTreeMap maintains sorted key order, so insertion order doesn't affect root"
  }
}
