{
  "$id": "https://northroot.dev/schemas/adr.index.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "ADR Index Schema",
  "description": "Schema for the machine-readable ADR index",
  "required": ["$schema", "version", "generated_at", "adrs"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "adrs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["adr_id", "slug", "title", "status", "created_at"],
        "properties": {
          "adr_id": {
            "type": "string",
            "pattern": "^ADR-\\d{4}$"
          },
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["proposed", "accepted", "rejected", "deprecated", "superseded", "unknown"]
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "domain": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "realized_at": {
            "type": "string",
            "format": "date-time",
            "description": "When first phase was implemented (realization timestamp)"
          },
          "phases": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["phase_id", "sequence", "status"],
              "properties": {
                "phase_id": {
                  "type": "string"
                },
                "sequence": {
                  "type": "integer"
                },
                "status": {
                  "type": "string"
                },
                "timestamp": {
                  "type": "string"
                },
                "implemented_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "implemented_in": {
                  "type": "string"
                },
                "implementation_commit": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}

