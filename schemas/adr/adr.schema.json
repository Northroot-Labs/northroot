{
  "$id": "https://northroot.dev/schemas/adr.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "ADR Schema",
  "description": "Schema for Architectural Decision Records",
  "required": ["adr_id", "slug", "title", "created_at", "status"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Path to schema file"
    },
    "adr_id": {
      "type": "string",
      "pattern": "^ADR-\\d{4}$",
      "description": "Canonical ADR identifier (e.g., ADR-0001)"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "URL-friendly slug (e.g., unified-config-layer)"
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "description": "Human-readable title"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["handle"],
        "properties": {
          "handle": { "type": "string" },
          "role": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "contributors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["handle"],
        "properties": {
          "handle": { "type": "string" },
          "role": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "accepted", "rejected", "deprecated", "superseded", "unknown"],
      "description": "Current status (derived from latest accepted phase)"
    },
    "domain": {
      "type": "string",
      "description": "Domain or area (e.g., platform, engine, storage)"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for categorization"
    },
    "related": {
      "type": "object",
      "properties": {
        "supersedes": {
          "type": "array",
          "items": { "type": "string", "pattern": "^ADR-\\d{4}$" }
        },
        "superseded_by": {
          "type": "array",
          "items": { "type": "string", "pattern": "^ADR-\\d{4}$" }
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string", "pattern": "^ADR-\\d{4}$" }
        },
        "related_to": {
          "type": "array",
          "items": { "type": "string", "pattern": "^ADR-\\d{4}$" }
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "ref"],
        "properties": {
          "type": { "type": "string" },
          "ref": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "decision_context": {
      "type": "object",
      "properties": {
        "problem": { "type": "string" },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "ai_provenance": {
      "type": "object",
      "description": "AI agent provenance tracking",
      "additionalProperties": true
    },
    "signing": {
      "type": "object",
      "description": "Content signing information",
      "properties": {
        "content_sha256": { "type": "string" },
        "signed_by": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

