{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://northroot.dev/schemas/data_shape.schema.json",
    "title": "DataShapePayload",
    "type": "object",
    "required": [
        "schema_hash"
    ],
    "properties": {
        "schema_hash": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "sketch_hash": {
            "type": ["string", "null"],
            "pattern": "^sha256:[0-9a-f]{64}$"
        }
    },
    "additionalProperties": false
}