{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.northroot.dev/method.v1.schema.json",
    "title": "Method Manifest v1",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schema_version",
        "method_id",
        "version",
        "nodes"
    ],
    "properties": {
        "schema_version": {
            "type": "string",
            "const": "method.v1"
        },
        "method_id": {
            "type": "string",
            "pattern": "^[a-z0-9_.-]+(/[a-z0-9_.-]+)*$",
            "description": "Unique method identifier, e.g. acme/inc_sum_pipeline"
        },
        "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
            "description": "Semantic version"
        },
        "nodes": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "id",
                    "span_shape_hash"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "span_shape_hash": {
                        "type": "string",
                        "pattern": "^sha256:[0-9a-f]{64}$"
                    }
                }
            }
        },
        "edges": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "from",
                    "to"
                ],
                "properties": {
                    "from": {
                        "type": "string"
                    },
                    "to": {
                        "type": "string"
                    }
                }
            },
            "description": "Directed edges between nodes (dataflow DAG)"
        },
        "runtime": {
            "type": "object",
            "additionalProperties": true,
            "description": "Runtime metadata (e.g. image_digest, method_fingerprint)"
        },
        "checker_refs": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Checkers or validators attached to this method"
        }
    }
}