{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://northroot.dev/schemas/execution.schema.json",
    "title": "ExecutionPayload",
    "type": "object",
    "required": [
        "trace_id",
        "method_ref",
        "data_shape_hash",
        "span_commitments",
        "roots"
    ],
    "properties": {
        "trace_id": {
            "type": "string",
            "minLength": 1
        },
        "method_ref": {
            "type": "object",
            "required": [
                "method_id",
                "version",
                "method_shape_root"
            ],
            "properties": {
                "method_id": {
                    "type": "string"
                },
                "version": {
                    "type": "string"
                },
                "method_shape_root": {
                    "type": "string",
                    "pattern": "^sha256:[0-9a-f]{64}$"
                }
            },
            "additionalProperties": false
        },
        "data_shape_hash": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "span_commitments": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
            }
        },
        "roots": {
            "type": "object",
            "required": [
                "trace_set_root",
                "identity_root"
            ],
            "properties": {
                "trace_set_root": {
                    "type": "string",
                    "pattern": "^sha256:[0-9a-f]{64}$"
                },
                "identity_root": {
                    "type": "string",
                    "pattern": "^sha256:[0-9a-f]{64}$"
                },
                "trace_seq_root": {
                    "type": ["string", "null"],
                    "pattern": "^sha256:[0-9a-f]{64}$"
                }
            },
            "additionalProperties": false
        },
        "cdf_metadata": {
            "type": ["array", "null"],
            "items": {
                "type": "object",
                "required": [
                    "commit_version",
                    "change_type",
                    "commit_timestamp"
                ],
                "properties": {
                    "commit_version": {
                        "type": "integer"
                    },
                    "change_type": {
                        "type": "string",
                        "enum": ["insert", "update", "delete", "no_change"]
                    },
                    "commit_timestamp": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "additionalProperties": false
            }
        },
        "pac": {
            "type": ["string", "null"],
            "description": "Proof-addressable cache key (base64-encoded 32-byte binary)"
        },
        "change_epoch": {
            "type": ["string", "null"],
            "description": "Change epoch: snapshot or commit ID (e.g., \"snap-123\", \"commit-abc\")"
        },
        "minhash_signature": {
            "type": ["string", "null"],
            "description": "MinHash signature for fast overlap estimation (base64-encoded binary)"
        },
        "hll_cardinality": {
            "type": ["integer", "null"],
            "description": "HyperLogLog cardinality estimate",
            "minimum": 0
        },
        "chunk_manifest_hash": {
            "type": ["string", "null"],
            "description": "Hash pointer to full chunk manifest (base64-encoded 32-byte binary)"
        },
        "chunk_manifest_size_bytes": {
            "type": ["integer", "null"],
            "description": "Size of uncompressed manifest in bytes",
            "minimum": 0
        },
        "merkle_root": {
            "type": ["string", "null"],
            "description": "Optional Merkle root for integrity verification (base64-encoded 32-byte binary)"
        },
        "prev_execution_rid": {
            "type": ["string", "null"],
            "description": "Previous execution RID for receipt chain (UUID format)",
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        }
    },
    "additionalProperties": false
}