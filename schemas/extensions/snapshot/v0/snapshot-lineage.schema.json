{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://northroot.dev/schemas/extensions/snapshot/v0/snapshot-lineage.schema.json",
  "title": "Northroot Snapshot Lineage v0",
  "type": "object",
  "required": [
    "schema",
    "parent_snapshot_digest",
    "covered_tip_event_id",
    "generated_by"
  ],
  "properties": {
    "schema": { "const": "northroot.snapshot_lineage.v0" },
    "parent_snapshot_digest": { "type": ["object", "null"] },
    "covered_tip_event_id": { "type": ["object", "null"] },
    "generated_by": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string" },
        "command": { "type": "string" },
        "receipt_ref": { "type": "string" },
        "event_ref": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
