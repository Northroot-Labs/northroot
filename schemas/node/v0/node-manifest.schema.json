{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://northroot.dev/schemas/node/v0/node-manifest.schema.json",
  "title": "Northroot Node Manifest V0",
  "type": "object",
  "required": ["schema", "node_id", "resource_namespace", "entity_namespace", "journal_path", "vault_path", "state_path"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "northroot.node-manifest.v0" },
    "node_id": { "type": "string", "pattern": "^node:.+" },
    "resource_namespace": { "type": "string", "minLength": 1 },
    "entity_namespace": { "type": "string", "minLength": 1 },
    "journal_path": { "type": "string", "pattern": "^journal(/.*)?$" },
    "vault_path": { "type": "string", "pattern": "^vault(/.*)?$" },
    "state_path": { "type": "string", "pattern": "^state(/.*)?$" }
  }
}
