{
  "schema_version": "northroot.custody.secret-bindings.v0",
  "bindings": [
    {
      "secret_ref": "secret://restic/local-password",
      "provider": "macos-keychain",
      "command": [
        "security",
        "find-generic-password",
        "-w",
        "-s",
        "northroot-restic-local-password",
        "-a",
        "northroot-steward"
      ],
      "requires_env": [],
      "interactive": false
    }
  ]
}
