{
  "adapter": "resticprofile",
  "consistency_boundaries": [
    {
      "id": "sqlite-online-copy",
      "preflight_ref": "preflight://sqlite-online-backup",
      "source_root_ids": [
        "sqlite-state"
      ],
      "type": "sqlite-online-backup"
    },
    {
      "id": "journal-seal",
      "preflight_ref": "preflight://journal-seal",
      "source_root_ids": [
        "journal-state"
      ],
      "type": "journal-seal"
    }
  ],
  "destinations": [
    {
      "adapter": "resticprofile",
      "id": "local-restic-profile",
      "repository_ref": "repository://local-primary",
      "secret_ref": "secret://restic/local-password"
    },
    {
      "adapter": "resticprofile",
      "id": "offsite-restic-copy",
      "repository_ref": "repository://offsite-vault"
    }
  ],
  "excludes": [
    "workspace://cache"
  ],
  "execution": {
    "custom_backup_engine": false,
    "kind": "delegated",
    "tool": "resticprofile"
  },
  "object_custody": [
    {
      "custody_policy": {
        "backup": "metadata-only",
        "retention": "git-remote-plus-steward-summary"
      },
      "object_id": "repo/main",
      "object_type": "repo",
      "redaction_policy": {
        "public_summary": "name-and-commit-only"
      },
      "restore_class": "metadata-only",
      "storage_binding": "workspace://.",
      "visibility": "public"
    },
    {
      "custody_policy": {
        "backup": "sqlite-online-backup",
        "verification": "sample-restore"
      },
      "object_id": "state/sqlite",
      "object_type": "sqlite",
      "redaction_policy": {
        "public_summary": "object-id-and-status"
      },
      "restore_class": "full-restore",
      "storage_binding": "workspace://state/app.sqlite",
      "visibility": "private"
    },
    {
      "custody_policy": {
        "backup": "journal-seal",
        "verification": "journal-replay"
      },
      "object_id": "journals/main",
      "object_type": "journal",
      "redaction_policy": {
        "public_summary": "object-id-and-seal-status"
      },
      "restore_class": "full-restore",
      "storage_binding": "journal://main",
      "visibility": "private"
    },
    {
      "custody_policy": {
        "backup": "excluded"
      },
      "object_id": "cache/runtime",
      "object_type": "cache",
      "redaction_policy": {
        "public_summary": "excluded-cache-count"
      },
      "restore_class": "never-export",
      "storage_binding": "cache://runtime",
      "visibility": "ephemeral"
    },
    {
      "custody_policy": {
        "backup": "provider-rehydrated",
        "verification": "binding-present"
      },
      "object_id": "secrets/restic-env",
      "object_type": "env-file",
      "redaction_policy": {
        "public_summary": "presence-only"
      },
      "restore_class": "rehydrate-from-provider",
      "storage_binding": "env://restic",
      "visibility": "secret"
    }
  ],
  "object_restore_classes": {
    "full-restore": [
      "state/sqlite",
      "journals/main"
    ],
    "metadata-only": [
      "repo/main"
    ],
    "never-export": [
      "cache/runtime"
    ],
    "rehydrate-from-provider": [
      "secrets/restic-env"
    ]
  },
  "policy_id": "example-policy",
  "retention": {
    "keep_daily": 7,
    "keep_weekly": 4,
    "prune_requires": [
      "verified_snapshot",
      "verified_offsite_copy",
      "restore_drill"
    ]
  },
  "retention_prune_requires": [
    "verified_snapshot",
    "verified_offsite_copy",
    "restore_drill"
  ],
  "schema_version": "northroot.custody.snapshot-plan.v0",
  "sources": [
    {
      "id": "sqlite-state",
      "path": "workspace://state/app.sqlite"
    },
    {
      "id": "journal-state",
      "path": "workspace://journals/main.nrj"
    }
  ],
  "verification_required": [
    "repository-check",
    "sample-restore",
    "journal-replay"
  ],
  "workspace_id": "example-workspace"
}
