{
  "schema_version": "northroot.custody.secret-bindings.v0",
  "bindings": [
    {
      "secret_ref": "secret://restic/local-password",
      "provider": "onepassword-cli",
      "command": [
        "op",
        "read",
        "op://ExampleVault/Restic/password"
      ],
      "requires_env": [
        "OP_SERVICE_ACCOUNT_TOKEN"
      ],
      "interactive": false
    }
  ],
  "runtime_env": [
    {
      "name": "OP_SERVICE_ACCOUNT_TOKEN",
      "provider": "macos-keychain",
      "command": [
        "security",
        "find-generic-password",
        "-w",
        "-s",
        "northroot-op-service-account-token",
        "-a",
        "northroot-steward"
      ],
      "interactive": false
    }
  ]
}
