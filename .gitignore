# Rust/Cargo
# Match target/ directories at any level (workspace or individual crates)
target/
**/target/
**/*.rs.bk
# Cargo.lock policy:
# - Root Cargo.lock: committed (for binaries/apps)
# - Library crates: no Cargo.lock (per Rust convention)
# - Binaries in apps/ and tools/: commit their own Cargo.lock
# Do NOT commit Cargo.lock for library crates in crates/
crates/**/Cargo.lock
*.pdb

# IDE
.idea/
# Keep .vscode/settings.json for workspace Python interpreter config
# .vscode/
*.swp
*.swo
*~
.DS_Store

# Build artifacts
*.o
*.so
*.dylib
*.dll
*.exe

# Test artifacts
*.test
test-results/
coverage/

# Documentation builds
/book/
/doc/

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# OS files
Thumbs.db
.DS_Store

# Policy registry (if local)
policies/local/
policies/*.local.json

# Test data (if generated)
testdata/generated/
vectors/generated/

# Python virtual environments
venv/
env/
.venv/
**/venv/
**/env/
**/venv/**
**/env/**

# Python build artifacts
**/dist/
**/build/
**/*.egg-info/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/*.pyw
**/*.pyz

# Rust build artifacts
**/target/
**/Cargo.lock
**/*.rs.bk
sdk/python/northroot/target/
sdk/python/northroot/Cargo.lock
sdk/python/northroot/**/*.rs.bk